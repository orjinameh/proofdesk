# ============================================
# ProofDesk Backend - Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit .env to source control.
# ============================================

# Server
PORT=4000
NODE_ENV=development

# CORS - comma separated list of allowed origins (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Database (optional - MVP runs fine without it, receipts are still
# generated and returned in-memory / logged. Set to enable persistence)
MONGODB_URI=

# Blockchain RPC (optional - used by ContractSecurityAgent /
# MarketStructureAgent when live checks are enabled)
RPC_URL=

# Third-party verification providers (optional).
# If these are missing, ProofDesk automatically runs in MOCK MODE,
# using realistic simulated verification data so the service still
# works end-to-end without any paid API keys.
GO_PLUS_API_KEY=
DEX_API_KEY=

# Only required if ProofDesk ever needs to sign anything on-chain
# (not used by the verification MVP). Leave blank for the hackathon demo.
PRIVATE_KEY=
